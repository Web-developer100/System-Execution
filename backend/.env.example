# =============================================================================
# V8 Neural Exploitation Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Usage: cp .env.example .env && edit .env

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=V8 Platform API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
WORKERS=4
CORS_ORIGINS=*

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://v8:v8password@localhost:5432/v8platform
DB_HOST=localhost
DB_PORT=5432
DB_NAME=v8platform
DB_USER=v8
DB_PASSWORD=v8password
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_ECHO=false

# ── Redis ────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Queue / Message Bus ──────────────────────────────────────────────────────
QUEUE_PROVIDER=rabbitmq
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# NATS_HOST=localhost
# NATS_PORT=4222

# ── Celery ────────────────────────────────────────────────────────────────────
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=change-me-in-production-use-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth2 Providers
# OAUTH2_GOOGLE_CLIENT_ID=
# OAUTH2_GOOGLE_CLIENT_SECRET=
# OAUTH2_GITHUB_CLIENT_ID=
# OAUTH2_GITHUB_CLIENT_SECRET=
# OAUTH2_MICROSOFT_CLIENT_ID=
# OAUTH2_MICROSOFT_CLIENT_SECRET=

# LDAP
# LDAP_ENABLED=false
# LDAP_SERVER_URL=ldap://localhost:389
# LDAP_BASE_DN=dc=example,dc=com

# SAML
# SAML_ENABLED=false
# SAML_ACS_URL=https://v8platform.com/api/v1/auth/saml/callback
# SAML_ENTITY_ID=https://v8platform.com

# WebAuthn / Passkeys
# WEBAUTHN_RP_ID=v8platform.com
# WEBAUTHN_ORIGIN=https://v8platform.com

# ── Storage (MinIO/S3) ────────────────────────────────────────────────────────
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
STORAGE_BUCKET=v8-platform

# ── AI / ML ─────────────────────────────────────────────────────────────────
AI_ENABLED=true
AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4-turbo

# ── Email / SMTP ────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@v8platform.com

# ── Observability ────────────────────────────────────────────────────────────
# SENTRY_DSN=https://...
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=5/15minute
RATE_LIMIT_SCANS=10/minute

# ── Feature Flags ───────────────────────────────────────────────────────────
FEATURE_AI_ANALYSIS=true
FEATURE_ATTACK_CHAINS=true
FEATURE_PLUGIN_MARKETPLACE=true
FEATURE_MFA=true
FEATURE_GRAPHQL=false
